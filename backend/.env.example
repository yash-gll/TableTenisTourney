# Backend environment configuration
# Copy to .env and adjust as needed.

# Postgres connection (psycopg3 driver)
DATABASE_URL=postgresql+psycopg://tt:tt@db:5432/tt

# JWT
JWT_SECRET=change-me-in-production
ACCESS_TOKEN_TTL_MINUTES=30
REFRESH_TOKEN_TTL_DAYS=14

# Auth token lifetimes (email verification / password reset), in hours
VERIFY_TOKEN_TTL_HOURS=48
RESET_TOKEN_TTL_HOURS=2

# Public base URL of the frontend, used to build verification/reset links in logs
FRONTEND_URL=http://localhost:5173

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:5173
